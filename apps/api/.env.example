# ── Database ──────────────────────────────────────────────────────────────────
# Railway: copy from the PostgreSQL service "Connect" tab
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/predictfi

# ── Cache / Rate-limiting ─────────────────────────────────────────────────────
# Railway: copy from the Redis service "Connect" tab
REDIS_URL=redis://default:PASSWORD@HOST:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-use-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────
API_PORT=4000
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-app.vercel.app

# ── Stellar ───────────────────────────────────────────────────────────────────
# "testnet" or "mainnet"
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
HORIZON_URL=https://horizon-testnet.stellar.org

# ── Contract Addresses ────────────────────────────────────────────────────────
MARKET_FACTORY_CONTRACT_ID=C...
POSITION_VAULT_CONTRACT_ID=C...
SETTLEMENT_CONTRACT_ID=C...
REPUTATION_CONTRACT_ID=C...
REGISTRY_CONTRACT_ID=C...

# ── Admin Keypair (required for oracle settlement) ────────────────────────────
# Generate with: stellar keys generate admin --network testnet
# CRITICAL: keep this secret — never commit to git
ADMIN_WALLET_SECRET=S...
ADMIN_WALLET_PUBLIC=G...
