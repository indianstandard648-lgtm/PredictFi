# ── Backend API ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api.railway.app/api/v1

# ── Stellar Network ───────────────────────────────────────────────────────────
# "testnet" or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Optional: override the default Soroban RPC endpoint
# Defaults: testnet → https://soroban-testnet.stellar.org
#           mainnet → https://soroban-mainnet.stellar.org
# NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ── Contract Addresses (deploy with contracts/deploy.sh) ──────────────────────
NEXT_PUBLIC_MARKET_FACTORY_CONTRACT=C...
NEXT_PUBLIC_POSITION_VAULT_CONTRACT=C...
NEXT_PUBLIC_SETTLEMENT_CONTRACT=C...
NEXT_PUBLIC_REPUTATION_CONTRACT=C...
NEXT_PUBLIC_REGISTRY_CONTRACT=C...
