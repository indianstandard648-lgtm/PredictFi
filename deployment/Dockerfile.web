# Build stage
FROM node:20-alpine AS builder
WORKDIR /app
COPY apps/web/package*.json ./
RUN npm ci
COPY apps/web/ .
# Pass build-time env vars via --build-arg in CI/CD
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_STELLAR_NETWORK=testnet
ARG NEXT_PUBLIC_STELLAR_RPC_URL
ARG NEXT_PUBLIC_MARKET_FACTORY_CONTRACT
ARG NEXT_PUBLIC_POSITION_VAULT_CONTRACT
ARG NEXT_PUBLIC_SETTLEMENT_CONTRACT
ARG NEXT_PUBLIC_REPUTATION_CONTRACT
ARG NEXT_PUBLIC_REGISTRY_CONTRACT
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_STELLAR_NETWORK=$NEXT_PUBLIC_STELLAR_NETWORK \
    NEXT_PUBLIC_STELLAR_RPC_URL=$NEXT_PUBLIC_STELLAR_RPC_URL \
    NEXT_PUBLIC_MARKET_FACTORY_CONTRACT=$NEXT_PUBLIC_MARKET_FACTORY_CONTRACT \
    NEXT_PUBLIC_POSITION_VAULT_CONTRACT=$NEXT_PUBLIC_POSITION_VAULT_CONTRACT \
    NEXT_PUBLIC_SETTLEMENT_CONTRACT=$NEXT_PUBLIC_SETTLEMENT_CONTRACT \
    NEXT_PUBLIC_REPUTATION_CONTRACT=$NEXT_PUBLIC_REPUTATION_CONTRACT \
    NEXT_PUBLIC_REGISTRY_CONTRACT=$NEXT_PUBLIC_REGISTRY_CONTRACT
RUN npm run build

# Runtime stage
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup -S predictfi && adduser -S predictfi -G predictfi

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

USER predictfi
EXPOSE 3000
ENV PORT=3000 HOSTNAME=0.0.0.0

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget -qO- http://localhost:3000/ || exit 1

CMD ["node", "server.js"]
